# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=smartappt
DB_PASSWORD=smartappt_secret
DATABASE_URL=postgresql://smartappt:smartappt_secret@localhost:5432/smartappt

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_PASSWORD=redis_secret

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_BASE64=<base64-encoded-RS256-private-key>
JWT_PUBLIC_KEY_BASE64=<base64-encoded-RS256-public-key>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
S3_BUCKET=smartappt-media
S3_SIGNED_URL_EXPIRY=900

# ── Firebase FCM ──────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=<base64-encoded-service-account-json>

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
TWILIO_MESSAGE_SERVICE_SID=<twilio-messaging-service-sid>
# Fallback: MSG91
MSG91_AUTH_KEY=<msg91-auth-key>
MSG91_SENDER_ID=<msg91-sender-id>
MSG91_TEMPLATE_ID=<msg91-template-id>

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=<sendgrid-api-key>
SENDGRID_FROM_EMAIL=noreply@appassoc.app
SENDGRID_FROM_NAME=SmartAppt

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=<razorpay-key-id>
RAZORPAY_KEY_SECRET=<razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret>

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_USER=100
RATE_LIMIT_MAX_PER_IP=500

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=15

# ── Encryption (AES-256 for PII fields) ──────────────────────────────────────
ENCRYPTION_KEY=<32-byte-hex-key>
ENCRYPTION_IV=<16-byte-hex-iv>

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
