{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://smart-appt-app-production.up.railway.app/api/v1/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
